<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#DCEFF6">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNavigationView">

        <LinearLayout
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- USER HEADER -->
            <LinearLayout
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp">

                <!-- Avatar -->
                <TextView
                    android:id="@+id/tvAvatar"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:gravity="center"
                    android:text="A"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:background="@drawable/avatar_bg"
                    android:layout_marginEnd="14dp"/>

                <!-- User Info -->
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tvWelcome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Welcome"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#D81B60"/>

                    <TextView
                        android:id="@+id/tvRole"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Role"
                        android:textColor="#777777"/>
                </LinearLayout>

            </LinearLayout>

            <!-- REWARD CARD -->
            <LinearLayout
                android:orientation="horizontal"
                android:background="@drawable/white_card_bg"
                android:padding="16dp"
                android:elevation="4dp"
                android:layout_marginBottom="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Reward Points -->
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reward Points"
                        android:textSize="13sp"
                        android:textColor="#777"/>

                    <TextView
                        android:id="@+id/tvRewardPoints"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#D81B60"/>
                </LinearLayout>

                <!-- Badge -->
                <LinearLayout
                    android:orientation="vertical"
                    android:gravity="end"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Badge"
                        android:textSize="13sp"
                        android:textColor="#777"/>

                    <TextView
                        android:id="@+id/tvBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bronze"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#D81B60"
                        android:padding="6dp"
                        android:background="@drawable/badge_bg"/>
                </LinearLayout>

            </LinearLayout>

            <!-- DASHBOARD BUTTON GRID -->
            <GridLayout
                android:columnCount="2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <Button
                    android:id="@+id/btnOfferHelp"
                    android:layout_width="0dp"
                    android:layout_height="70dp"
                    android:layout_columnWeight="1"
                    android:text="📋 Available Jobs"
                    android:textAllCaps="false"
                    android:backgroundTint="#D81B60"
                    android:textColor="@android:color/white"
                    android:layout_margin="6dp"/>

                <Button
                    android:id="@+id/btnMyJobs"
                    android:layout_width="0dp"
                    android:layout_height="70dp"
                    android:layout_columnWeight="1"
                    android:text="🛠 My Jobs"
                    android:textAllCaps="false"
                    android:backgroundTint="#D81B60"
                    android:textColor="@android:color/white"
                    android:layout_margin="6dp"/>

                <Button
                    android:id="@+id/btnLeaderboard"
                    android:layout_width="0dp"
                    android:layout_height="70dp"
                    android:layout_columnWeight="1"
                    android:text="🏆 Leaderboard"
                    android:textAllCaps="false"
                    android:backgroundTint="#D81B60"
                    android:textColor="@android:color/white"
                    android:layout_margin="6dp"/>

                <Button
                    android:id="@+id/btnChats"
                    android:layout_width="0dp"
                    android:layout_height="70dp"
                    android:layout_columnWeight="1"
                    android:text="💬 Chats"
                    android:textAllCaps="false"
                    android:backgroundTint="#D81B60"
                    android:textColor="@android:color/white"
                    android:layout_margin="6dp"/>

                <Button
                    android:id="@+id/btnMaps"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:layout_columnSpan="2"
                    android:text="🗺 Maps"
                    android:textAllCaps="false"
                    android:backgroundTint="#D81B60"
                    android:textColor="@android:color/white"
                    android:layout_margin="6dp"/>

            </GridLayout>

        </LinearLayout>

    </ScrollView>

    <!-- REQUEST HELP BUTTON -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabRequestHelp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@android:drawable/ic_input_add"
        android:layout_margin="16dp"
        android:layout_above="@id/bottomNavigationView"
        android:layout_alignParentEnd="true"
        android:tint="@android:color/white"
        android:backgroundTint="#D81B60"/>

    <!-- BOTTOM NAVIGATION -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#D81B60"
        app:itemIconTint="@color/bottom_nav_color"
        app:itemTextColor="@color/bottom_nav_color"
        app:menu="@menu/bottom_nav_menu"/>

</RelativeLayout>