<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#DCEFF6">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Top Red Bar -->
        <View
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="#D81B60"/>

        <LinearLayout
            android:orientation="vertical"
            android:padding="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Welcome -->
            <TextView
                android:id="@+id/tvWelcome"
                android:text="Welcome"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#D81B60"
                android:layout_marginBottom="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvRole"
                android:text="Role"
                android:textColor="#777777"
                android:layout_marginBottom="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- Reward Card -->
            <LinearLayout
                android:orientation="vertical"
                android:background="@drawable/white_card_bg"
                android:elevation="6dp"
                android:padding="20dp"
                android:layout_marginBottom="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="Reward Points"
                    android:textStyle="bold"
                    android:textColor="@android:color/black"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvRewardPoints"
                    android:text="0"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#D81B60"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvBadge"
                    android:text="Badge"
                    android:textColor="#777777"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <!-- Buttons -->

            <Button
                android:id="@+id/btnRequestHelp"
                android:text="Request Help"
                android:textColor="@android:color/white"
                android:backgroundTint="#D81B60"
                android:layout_marginBottom="12dp"
                android:layout_width="match_parent"
                android:layout_height="50dp"/>

            <Button
                android:id="@+id/btnOfferHelp"
                android:text="View Requests"
                android:textColor="@android:color/white"
                android:backgroundTint="#D81B60"
                android:layout_marginBottom="12dp"
                android:layout_width="match_parent"
                android:layout_height="50dp"/>

            <Button
                android:id="@+id/btnMyJobs"
                android:text="My Jobs"
                android:textColor="@android:color/white"
                android:backgroundTint="#D81B60"
                android:layout_marginBottom="12dp"
                android:layout_width="match_parent"
                android:layout_height="50dp"/>

            <Button
                android:id="@+id/btnLeaderboard"
                android:text="Leaderboard"
                android:textColor="@android:color/white"
                android:backgroundTint="#D81B60"
                android:layout_marginBottom="12dp"
                android:layout_width="match_parent"
                android:layout_height="50dp"/>

            <Button
                android:id="@+id/btnChats"
                android:text="Chats"
                android:textColor="@android:color/white"
                android:backgroundTint="#D81B60"
                android:layout_marginBottom="12dp"
                android:layout_width="match_parent"
                android:layout_height="50dp"/>

            <Button
                android:id="@+id/btnMaps"
                android:text="Maps"
                android:textColor="@android:color/white"
                android:backgroundTint="#D81B60"
                android:layout_width="match_parent"
                android:layout_height="50dp"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>